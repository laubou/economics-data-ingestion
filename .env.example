# Copy this file to .env (local dev) and fill in the blanks.
# For cloud environments, set these variables in your ECS task definition or CI secrets.
# All variables use the PIPELINE_ prefix (see PipelineSettings in packages/).

PIPELINE_ENVIRONMENT=dev

# ---- Kafka ----
PIPELINE_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PIPELINE_KAFKA_TOPIC=sales-events
PIPELINE_KAFKA_GROUP_ID=bronze-consumer-group
PIPELINE_KAFKA_NUM_PARTITIONS=3
PIPELINE_KAFKA_REPLICATION_FACTOR=1

# ---- Storage (local dev: leave S3_BUCKET empty) ----
PIPELINE_DATA_BASE_PATH=data
PIPELINE_S3_BUCKET=

# ---- AWS (required when S3_BUCKET is set) ----
PIPELINE_AWS_REGION=eu-west-1
PIPELINE_GLUE_DATABASE=economics_pipeline

# ---- Source ----
PIPELINE_SOURCE_URL=https://eforexcel.com/wp/wp-content/uploads/2020/09/2m-Sales-Records.zip
PIPELINE_SOURCE_FILENAME=2m Sales Records.csv

# ---- Dev safety guard ----
# Limit rows processed — unset or empty = unlimited (use in prod)
PIPELINE_MAX_ROWS=1000
